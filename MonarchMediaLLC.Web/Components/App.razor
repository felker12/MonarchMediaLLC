<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["MonarchMediaLLC.Web.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet @rendermode="InteractiveServer" />
</head>

<body>
    <Routes @rendermode="InteractiveServer" />

    <script src="@Assets["_framework/blazor.web.js"]"></script>

    <script>
        window.initSidebarResizeListener = (dotNetHelper) => {
        // Run once on load to see if window is already small
        if (window.innerWidth <= 768) {
        dotNetHelper.invokeMethodAsync('SetSidebarState', true);
        }

        // Listen for browser window resizes
        window.addEventListener('resize', () => {
        if (window.innerWidth <= 768) {
        dotNetHelper.invokeMethodAsync('SetSidebarState', true); // Collapse it
        } else {
        dotNetHelper.invokeMethodAsync('SetSidebarState', false); // Expand it
        }
        });
        };
    </script>
</body>

</html>