<div class="navmenu-container @(IsSidebarCollapsed ? "sidebar-collapsed" : "")">

    <div class="sidebar-header">
        <div class="logo-container">
            <img src="BgButterflyBlack.svg"
                 alt="Company Logo"
                 class="logo-img" />
        </div>

        <button class="btn-toggle"
                @onclick="() => OnToggleSidebar.InvokeAsync()"
                aria-label="Toggle Navigation">
            <span class="toggle-arrow"></span>
        </button>
    </div>

    <div class="nav-scrollable">
        <nav class="nav flex-column">

            @foreach (var link in NavigationLinks)
            {
                <div class="nav-item">
                    <NavLink class="nav-link" href="@link.Href" Match="@link.Match">
                        <img src="@link.IconPath" alt="" class="nav-icon" />
                        <span class="nav-text">@link.Label</span>
                    </NavLink>
                </div>
            }

        </nav>
    </div>
</div>

@code {
    [Parameter]
    public bool IsSidebarCollapsed { get; set; }

    [Parameter]
    public EventCallback OnToggleSidebar { get; set; }

    private class NavLinkItem
    {
        public string Href { get; set; } = string.Empty;
        public string Label { get; set; } = string.Empty;
        public string IconPath { get; set; } = string.Empty;
        public NavLinkMatch Match { get; set; } = NavLinkMatch.Prefix;
    }

    private List<NavLinkItem> NavigationLinks => new()
    {
        new NavLinkItem { Href = "", Label = "Home", Match = NavLinkMatch.All, IconPath = "icons/house-door-fill.svg" },
        new NavLinkItem { Href = "about", Label = "About", IconPath = "icons/file-person-fill.svg" },
        new NavLinkItem { Href = "project-overview", Label = "Project Overview", IconPath = "icons/list-task.svg" },
        new NavLinkItem { Href = "projects", Label = "Projects", IconPath = "icons/folder-fill.svg" },
        new NavLinkItem { Href = "contact", Label = "Contact", IconPath = "icons/chat-left-text.svg" },
    };
}