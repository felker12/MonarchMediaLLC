@inherits LayoutComponentBase
@inject IJSRuntime JS
@implements IDisposable

<div class="page">
    <div class="sidebar @(isCollapsed ? "sidebar-collapsed" : "")">
        <NavMenu IsSidebarCollapsed="isCollapsed"
                 OnToggleSidebar="ToggleSidebar" />
    </div>

    <main>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private bool isCollapsed;
    private DotNetObjectReference<MainLayout>? objRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            objRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("initSidebarResizeListener", objRef);
        }
    }

    private void ToggleSidebar()
    {
        isCollapsed = !isCollapsed;
        StateHasChanged();
    }

    [JSInvokable]
    public void SetSidebarState(bool shouldCollapse)
    {
        if (isCollapsed != shouldCollapse)
        {
            isCollapsed = shouldCollapse;
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        objRef?.Dispose();
    }
}