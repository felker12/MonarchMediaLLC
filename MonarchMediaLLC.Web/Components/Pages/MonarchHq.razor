@page "/monarch-hq"
@using MonarchMediaLLC.Shared
@using MonarchMediaLLC.Web.Services
@inject HttpClient Http
@inject AdminStateProvider AdminState
@rendermode InteractiveServer

<PageTitle>HQ Portal Control</PageTitle>

<div class="hq-container">
    @if (!AdminState.IsAuthenticated)
    {
        <div class="login-card animate-fade-in">
            <div class="lock-header">
                <div class="lock-icon">🔒</div>
                <h2>Monarch HQ</h2>
                <p>System operational override required.</p>
            </div>

            <EditForm Model="@loginModel" OnValidSubmit="HandleLogin" FormName="HqLoginForm">
                <div class="form-group mb-3">
                    <label class="form-label">Operator Username</label>
                    <input type="text" class="form-control" @bind-value="loginModel.UserName" required autocomplete="off" />
                </div>

                <div class="form-group mb-4">
                    <label class="form-label">Secret Passkey</label>
                    <input type="password" class="form-control" @bind-value="loginModel.Passkey" required />
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger py-2 mb-3">@errorMessage</div>
                }

                <button type="submit" class="btn btn-primary w-100 py-2" disabled="@isSubmitting">
                    @(isSubmitting ? "Verifying..." : "Authenticate")
                </button>
            </EditForm>
        </div>
    }
    else
    {
        <div class="dashboard-wrapper animate-fade-in">
            <header class="dashboard-header">
                <div>
                    <h1>Welcome Back, <span class="text-gradient">@AdminState.Username</span></h1>
                    <p>Database Management Console & System Operations</p>
                </div>
                <button class="btn btn-outline-danger" @onclick="HandleLogout">Terminate Session</button>
            </header>

            @if (!string.IsNullOrEmpty(statusMessage))
            {
                <div class="alert alert-success mb-4 text-center">@statusMessage</div>
            }

            <div class="dashboard-grid">
                <div class="mgmt-card">
                    <h3>Deploy New Project Card</h3>
                    <EditForm Model="@projectModel" OnValidSubmit="SubmitProject" FormName="AddProjectForm">
                        <div class="mb-3">
                            <label class="form-label">Project Title</label>
                            <input type="text" class="form-control" @bind-value="projectModel.Title" required placeholder="e.g., Southard Homes" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <textarea class="form-control" @bind="projectModel.Description" required rows="2" placeholder="Brief platform summary..."></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Tech Stack Tags</label>
                            <input type="text" class="form-control" @bind-value="projectModel.TechStack" required placeholder="e.g., Astro • TS • Tailwind" />
                        </div>
                        <div class="mb-4">
                            <label class="form-label">Launch URL</label>
                            <input type="url" class="form-control" @bind-value="projectModel.Url" required placeholder="https://..." />
                        </div>
                        <button type="submit" class="btn btn-primary w-100" disabled="@isSaving">Commit to Database</button>
                    </EditForm>
                </div>

                <div class="mgmt-card">
                    <h3>Provision Team Roster</h3>
                    <EditForm Model="@teamModel" OnValidSubmit="SubmitTeamMember" FormName="AddTeamForm">
                        <div class="mb-3">
                            <label class="form-label">Full Name</label>
                            <input type="text" class="form-control" @bind-value="teamModel.Name" required placeholder="Full Name" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Corporate Role</label>
                            <input type="text" class="form-control" @bind-value="teamModel.Role" required placeholder="e.g., Marketing Manager" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Professional Bio</label>
                            <textarea class="form-control" @bind="teamModel.Bio" required rows="2" placeholder="Bio description..."></textarea>
                        </div>
                        <div class="mb-4">
                            <label class="form-label">Avatar Asset Path</label>
                            <input type="text" class="form-control" @bind-value="teamModel.ImagePath" required placeholder="images/team/filename.jpg" />
                        </div>
                        <button type="submit" class="btn btn-primary w-100" disabled="@isSaving">Commit to Database</button>
                    </EditForm>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private AdminLoginRequest loginModel = new();
    private ProjectSummary projectModel = new();
    private TeamMember teamModel = new();
    
    private string errorMessage = string.Empty;
    private string statusMessage = string.Empty;
    private bool isSubmitting = false;
    private bool isSaving = false;

    private async Task HandleLogin()
    {
        isSubmitting = true;
        errorMessage = string.Empty;

        try
        {
            //Post directly using JsonContent body serialization
            var response = await Http.PostAsJsonAsync("/api/admin/verify", loginModel);

            if (response.IsSuccessStatusCode)
            {
                AdminState.Login(loginModel.UserName, loginModel.Passkey);
            }
            else
            {
                errorMessage = "Invalid operator credentials or unauthorized security layer.";
            }
        }
        catch (Exception)
        {
            errorMessage = "Unable to route validation request to ApiService engine.";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task SubmitProject()
    {
        isSaving = true;
        statusMessage = string.Empty;
        
        try 
        {
            using var request = new HttpRequestMessage(HttpMethod.Post, "http://apiservice/api/projects");
            request.Headers.Add("X-Admin-Token", AdminState.Token);
            request.Content = JsonContent.Create(projectModel);

            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                statusMessage = $"Successfully deployed project '{projectModel.Title}' into SQLite system storage.";
                projectModel = new(); // Reset the data model bound to the form
            }
            else
            {
                errorMessage = "Failed to save project. Verify authentication headers.";
            }
        }
        catch (Exception)
        {
            errorMessage = "Network transport failure updating backend database records.";
        }
        finally 
        {
            isSaving = false;
        }
    }

    private async Task SubmitTeamMember()
    {
        isSaving = true;
        statusMessage = string.Empty;

        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Post, "http://apiservice/api/team");
            request.Headers.Add("X-Admin-Token", AdminState.Token);
            request.Content = JsonContent.Create(teamModel);

            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                statusMessage = $"Successfully provisioned {teamModel.Name} to the live organizational roster.";
                teamModel = new(); // Reset the data model bound to the form
            }
            else
            {
                errorMessage = "Failed to save team member. Verify authentication headers.";
            }
        }
        catch (Exception)
        {
            errorMessage = "Network transport failure updating backend database records.";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void HandleLogout()
    {
        AdminState.Logout();
        statusMessage = string.Empty;
        errorMessage = string.Empty;
    }
}