@page "/monarch-hq/dashboard"
@using MonarchMediaLLC.Web.Services
@inject AdminStateProvider AdminState
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>HQ Control Panel Workspace</PageTitle>

<div class="dashboard-container">
    @if (!AdminState.IsAuthenticated)
    {
        <div class="alert alert-danger m-5 text-center">
            <h3>⚠️ Unauthorized Access Blocked</h3>
            <p>Redirecting to central authorization checkpoint...</p>
        </div>
    }
    else
    {
        <div class="dashboard-wrapper animate-fade-in">
            <header class="dashboard-header mb-4">
                <div>
                    <h1>Welcome Back, <span class="text-gradient">@AdminState.Username</span></h1>
                    <p>Central Operations Hub & Management Console</p>
                </div>
            </header>

            <div class="dashboard-grid">
                <!-- Projects Management Navigation Card -->
                <div class="mgmt-card text-center d-flex flex-column justify-content-between">
                    <div>
                        <h3>Project Portfolio</h3>
                        <p class="text-muted">Deploy new client project components, manage existing database targets, and configure live system URLs.</p>
                    </div>
                    <div class="mt-4">
                        <NavLink class="btn btn-primary w-100 py-2" href="monarch-hq/projects">
                            Open Project Manager →
                        </NavLink>
                    </div>
                </div>

                <!-- Team Management Navigation Card -->
                <div class="mgmt-card text-center d-flex flex-column justify-content-between">
                    <div>
                        <h3>Team Roster</h3>
                        <p class="text-muted">Provision corporate profiles, edit organizational backgrounds, and assign static file asset paths.</p>
                    </div>
                    <div class="mt-4">
                        <NavLink class="btn btn-primary w-100 py-2" href="monarch-hq/team">
                            Open Roster Manager →
                        </NavLink>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender && !AdminState.IsAuthenticated)
        {
            Navigation.NavigateTo("/monarch-hq", forceLoad: false);
        }
    }
}