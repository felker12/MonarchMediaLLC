@page "/about"
@inject HttpClient Http
<PageTitle>About</PageTitle>

<div class="about-container">
    <!-- ==========================================================
         HERO
    =========================================================== -->
    <section class="hero-section">
        <h1 class="hero-title">
            The Blueprint Behind
            <br />
            <span class="text-coloring">The Performance</span>
        </h1>

        <p class="hero-subtitle">
            Monarch Media LLC is a software development and digital solutions
            studio focused on building fast websites, scalable web applications,
            and modern business systems that help companies grow.
        </p>
    </section>

    <!-- ==========================================================
         WHY WE EXIST
    =========================================================== -->
    <section class="hero-section">
        <h2 class="section-title">
            Why <span class="text-coloring">Monarch</span> Exists
        </h2>

        <p class="hero-subtitle">
            Most agencies stop after launching a beautiful website.
        </p>

        <p class="hero-subtitle">
            We believe technology should become part of how a business operates,
            not just how it looks online.
        </p>

        <p class="hero-subtitle">
            That's why we combine modern software engineering with professional
            branding to create systems that improve marketing, streamline
            operations, and support long-term growth.
        </p>
    </section>

    <!-- ==========================================================
         PRINCIPLES
    =========================================================== -->
    <section class="principles-section">
        <h2 class="section-title">
            Everything We Build Is <span class="text-coloring">Guided By Four Principles</span>
        </h2>

        <p class="section-subtitle">
            Every project is designed with these core values from day one.
        </p>

        <div class="principles-grid">

            <div class="principle">
                <span class="principle-number">01</span>

                <h3>Performance</h3>

                <p>
                    Fast websites create better user experiences, rank higher in
                    search engines, and convert more visitors into customers.
                </p>
            </div>

            <div class="principle">
                <span class="principle-number">02</span>

                <h3>Security</h3>

                <p>
                    From secure authentication to protected databases, we build
                    software that businesses can trust.
                </p>
            </div>

            <div class="principle">
                <span class="principle-number">03</span>

                <h3>Scalability</h3>

                <p>
                    Your technology should grow alongside your business instead
                    of needing to be rebuilt every few years.
                </p>
            </div>

            <div class="principle">
                <span class="principle-number">04</span>

                <h3>Automation</h3>

                <p>
                    Repetitive work should be handled by software so your team
                    can focus on serving customers and growing the business.
                </p>
            </div>
        </div>
    </section>

    <!-- ==========================================================
         WHAT WE BUILD
    =========================================================== -->
    <section class="values-section">
        <h2 class="section-title">
            What We Build
        </h2>

        <p class="section-subtitle">
            Every solution is custom engineered around your goals—not forced
            into a one-size-fits-all template.
        </p>

        <div class="values-grid">
            <div class="value-card">
                <img src="icons/lightning-charge-fill.svg"
                     class="value-icon"
                     alt="" />

                <h3>High-Performance Websites</h3>

                <p>
                    Built with modern frameworks like Astro to maximize speed,
                    SEO, accessibility, and long-term maintainability.
                </p>

            </div>

            <div class="value-card">
                <img src="icons/layer-backward.svg"
                     class="value-icon"
                     alt="" />

                <h3>Custom Business Applications</h3>

                <p>
                    Internal dashboards, customer portals, API integrations,
                    database systems, and business software built around your
                    workflow.
                </p>

            </div>

            <div class="value-card">

                <img src="icons/shield-check.svg"
                     class="value-icon"
                     alt="" />

                <h3>Reliable Software</h3>

                <p>
                    Modern engineering practices, strong typing, testing, and
                    scalable architecture ensure software that continues working
                    as your business grows.
                </p>
            </div>
        </div>
    </section>

    <!-- ==========================================================
         OUR PROCESS
    =========================================================== -->
    <section class="process-section">
        <h2 class="section-title">
            Our Process
        </h2>

        <p class="section-subtitle">
            Every successful project follows a clear roadmap—from the first
            conversation to long-term support.
        </p>

        <div class="process-card">
            <div class="process-flow">
                @for (int i = 0; i < ProcessSteps.Count; i++)
                {
                    var step = ProcessSteps[i];

                    <div class="process-item">
                        <div class="process-step">
                            <div class="process-circle">
                                @step.Title
                            </div>

                            <p>@step.Description</p>
                        </div>

                        @if (i < ProcessSteps.Count - 1)
                        {
                            <div class="process-arrow">

                                <img class="desktop-arrow"
                                     src="/icons/arrow-right.svg"
                                     alt="" />

                                <img class="mobile-arrow"
                                     src="/icons/arrow-down.svg"
                                     alt="" />

                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </section>

    <!-- ==========================================================
         TEAM
    =========================================================== -->
    <section class="gallery-section">

        <h2 class="section-title">
            Meet The Minds
        </h2>

        <p class="section-subtitle">
            The people behind the strategy, engineering, and creativity that
            power every Monarch Media project.
        </p>

        @if (TeamMembers == null)
        {
            <div class="text-center py-5">

                <span class="spinner-border spinner-border-sm me-2"></span>

                Loading team members...
            </div>
        }
        else if (!TeamMembers.Any())
        {
            <div class="text-center py-5 text-muted">

                Team members will appear here as they're added.

            </div>
        }
        else
        {
            <div class="team-grid">
                @foreach (var member in TeamMembers)
                {
                    <div class="team-card">

                        <div class="avatar-wrapper">
                            <img src="@member.ImagePath"
                                 alt="@member.Name"
                                 class="avatar-img" />
                        </div>

                        <div class="team-info">
                            <h4>@member.Name</h4>

                            <span class="team-role">
                                @member.Role
                            </span>

                            <p class="team-bio">
                                @member.Bio
                            </p>
                        </div>
                    </div>
                }
            </div>
        }
    </section>

    <!-- ==========================================================
         CTA
    =========================================================== -->
    <section class="cta-section">
        <div class="cta-card">
            <h2 class="section-title">
                Let's Build Something Great Together
            </h2>
            <p class="section-subtitle">
                Whether you're launching a new business, modernizing an existing website, 
                or developing custom software, we'd love to help bring your ideas to life.
            </p>
            <div class="cta-link-card">
                <NavLink class="btn btn-primary"
                         href="/contact">
                    Start Your Project
                </NavLink>
            </div>
        </div>
    </section>
</div>

@code {
    private List<TeamMember>? TeamMembers;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            TeamMembers =
                await Http.GetFromJsonAsync<List<TeamMember>>(
                    "http://apiservice/api/team");
        }
        catch
        {
            TeamMembers = new();
        }
    }

    private sealed class TeamMember
    {
        public string Name { get; set; } = "";
        public string Role { get; set; } = "";
        public string Bio { get; set; } = "";
        public string ImagePath { get; set; } = "";
    }

    private readonly List<ProcessStep> ProcessSteps =
    [
        new("Discovery",
            "We learn about your business, goals, audience, and current challenges before planning the solution."),

        new("Design",
            "Wireframes, branding, user experience, and technical planning ensure everyone is aligned before development."),

        new("Build",
            "Using modern frameworks and clean architecture, we build software focused on performance, security, and maintainability."),

        new("Launch",
            "Thorough testing and deployment ensure a smooth release with minimal disruption to your business."),

        new("Growth",
            "We continue improving your platform through maintenance, optimization, analytics, automation, and future development.")
    ];

    private record ProcessStep(string Title, string Description);
}